<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-3.0.xsd">

    <service verb="send" noun="Prompt" type="inline">
        <in-parameters>
            <parameter name="promptText" required="true"/>
            <parameter name="componentId" default-value="facility-alerts"/>
        </in-parameters>
        <out-parameters>
            <parameter name="responseText" required="true"/>
        </out-parameters>
        <actions>
            <script location="component://agi-ai/service/org/moqui/ai/GeminiServices.groovy"/>
        </actions>
    </service>

    <service verb="load" noun="DynamicTools">
        <description>Programmatically discover Ean's moqui-mcp tools and return them as Google ADK-compatible FunctionTool definitions.</description>
        <out-parameters>
            <parameter name="toolsList" type="List"><description>List of FunctionTool instances</description></parameter>
        </out-parameters>
        <actions>
            <script><![CDATA[
                context.toolsList = org.moqui.ai.AdkMcpBridge.getTools()
            ]]></script>
        </actions>
    </service>

    <service verb="get" noun="ScreenCanvasTree">
        <in-parameters>
            <parameter name="screenLocation" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="canvasTree" type="Map"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                context.canvasTree = org.moqui.ai.ScreenEditorServices.getScreenCanvasTree(screenLocation, ec)
            ]]></script>
        </actions>
    </service>

    <service verb="get" noun="Blueprint" authenticate="false">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
            <parameter name="renderTargetOnly" type="String"/>
            <parameter name="renderDepth" type="String"/>
        </in-parameters>
        <out-parameters>
            <parameter name="blueprint" type="Map"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                context.blueprint = org.moqui.ai.ScreenEditorServices.getBlueprint(componentName, screenPath, ec).blueprint
            ]]></script>
        </actions>
    </service>

    <service verb="save" noun="Blueprint" authenticate="false">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
            <parameter name="blueprint" type="Map" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="success" type="Boolean"/>
            <parameter name="message" type="String"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                def res = org.moqui.ai.ScreenEditorServices.saveBlueprint(componentName, screenPath, blueprint, ec)
                context.success = res.success
                context.message = res.message
            ]]></script>
        </actions>
    </service>

    <service verb="register" noun="Client" authenticate="false">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
        </in-parameters>
        <actions>
            <script><![CDATA[
                org.moqui.ai.ScreenEditorServices.registerClient(componentName, screenPath, ec)
            ]]></script>
        </actions>
    </service>

    <service verb="get" noun="UiMacros" authenticate="false">
        <out-parameters>
            <parameter name="macros" type="Map"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                context.macros = org.moqui.ai.ScreenEditorServices.getUiMacros(ec).macros
            ]]></script>
        </actions>
    </service>

    <service verb="push" noun="BlueprintUpdate" authenticate="false">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
        </in-parameters>
        <actions>
            <script><![CDATA[
                org.moqui.ai.ScreenEditorServices.pushBlueprintUpdate(componentName, screenPath, ec)
            ]]></script>
        </actions>
    </service>
</services>
