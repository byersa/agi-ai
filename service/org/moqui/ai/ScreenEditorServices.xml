<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-2.1.xsd">

    <service verb="get" noun="Blueprint" transaction="force-new" transaction-timeout="300">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
            <parameter name="renderDepth" type="Integer"/>
            <parameter name="renderTargetOnly" type="String"/>
        </in-parameters>
        <out-parameters>
            <parameter name="blueprint" type="Map"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                // Inject the standard application context explicitly into the parameters map
                ec.context.put("renderMode", "qjson")
                
                // Route the request straight into our high-fidelity service method
                context.blueprint = org.moqui.ai.ScreenEditorServices.getBlueprint(componentName, screenPath, ec)
            ]]></script>
        </actions>
    </service>

    <service verb="save" noun="Blueprint">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
            <parameter name="blueprint" type="Map" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="success" type="Boolean"/>
            <parameter name="message" type="String"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                def result = org.moqui.ai.ScreenEditorServices.saveBlueprint(componentName, screenPath, blueprint, ec)
                context.putAll(result)
            ]]></script>
        </actions>
    </service>

    <service verb="register" noun="Client">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
        </in-parameters>
        <actions>
            <script><![CDATA[
                org.moqui.ai.ScreenEditorServices.registerClient(componentName, screenPath, ec)
            ]]></script>
        </actions>
    </service>

    <service verb="push" noun="BlueprintUpdate">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
        </in-parameters>
        <actions>
            <script><![CDATA[
                org.moqui.ai.ScreenEditorServices.pushBlueprintUpdate(componentName, screenPath, ec)
            ]]></script>
        </actions>
    </service>

    <service verb="get" noun="UiMacros">
        <out-parameters>
            <parameter name="macros" type="Map"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                context.putAll(org.moqui.ai.ScreenEditorServices.getUiMacros(ec))
            ]]></script>
        </actions>
    </service>

</services>